# Alphabetical Tutor (A–Z)

alphabet_words = {
    "a": ["Apple", "Ant", "Aeroplane", "Animal", "Arrow"],
    "b": ["Ball", "Bat", "Banana", "Book", "Boy"],
    "c": ["Cat", "Car", "Cow", "Cup", "Cake"],
    "d": ["Dog", "Duck", "Door", "Drum", "Doll"],
    "e": ["Elephant", "Egg", "Earth", "Eagle", "Engine"],
    "f": ["Fish", "Fan", "Flower", "Flag", "Frog"],
    "g": ["Goat", "Gun", "Grapes", "Glass", "Girl"],
    "h": ["Hat", "Hen", "Horse", "House", "Hand"],
    "i": ["Ice", "Ink", "Iron", "Insect", "Island"],
    "j": ["Jug", "Jam", "Jeep", "Jacket", "Juice"],
    "k": ["Kite", "Key", "King", "Knife", "Kangaroo"],
    "l": ["Lion", "Lamp", "Leaf", "Lemon", "Lock"],
    "m": ["Monkey", "Mango", "Milk", "Mouse", "Moon"],
    "n": ["Nest", "Net", "Nose", "Night", "Notebook"],
    "o": ["Orange", "Owl", "Ocean", "Ox", "Onion"],
    "p": ["Parrot", "Pen", "Pencil", "Pumpkin", "Phone"],
    "q": ["Queen", "Question", "Quill", "Quick", "Quiet"],
    "r": ["Rat", "Rose", "Ring", "Rabbit", "Road"],
    "s": ["Sun", "Star", "Ship", "Snake", "School"],
