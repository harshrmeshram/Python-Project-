    "y": ["Yak", "Yellow", "Yarn", "Yogurt", "Youth"],
    "z": ["Zebra", "Zoo", "Zero", "Zip", "Zone"]
}

print("🔤 Alphabetical Tutor (A–Z)")
print("Type a letter (a-z) or type 'exit' to quit\n")

while True:
    letter = input("Enter a letter: ").lower()

    if letter == "exit":
        print("👋 Thank you for learning!")
        break

    if letter in alphabet_words:
        print(f"📘 Words starting with '{letter.upper()}':")
        for word in alphabet_words[letter]:
            print("•", word)
        print()
    else:
        print("❌ Please enter a valid letter (a–z)\n")
